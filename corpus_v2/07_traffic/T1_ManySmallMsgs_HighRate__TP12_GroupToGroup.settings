# Corpus v2 traffic profile (TP12 GroupToGroup) — generated from corpus_v1. Mobility unchanged; Events* and Group*.msgTtl overridden.
# =========================================================
# T1 - Many small messages
# 1–5 KB messages, high creation rate.
# Levers: Events1.size 1k–5k, Events1.interval low.
# =========================================================

Scenario.name = T1_ManySmallMsgs_HighRate__TP12_GroupToGroup
Scenario.simulateConnections = true
Scenario.updateInterval = 0.1
Scenario.endTime = 43200
MovementModel.rngSeed = 51
# Diversificación estructural vs T9/T13 (mantener grupo Traffic): mundo más pequeño que T9
MovementModel.worldSize = 5000, 3800

Group.movementModel = RandomWaypoint
Group.router = EpidemicRouter
Group.nrofHosts = 36
# Diversificar core 24 vs T9
Group.bufferSize = 12M
Group.nrofInterfaces = 1
Group.interface1 = bt0
Group.speed = 0.5, 1.2
Group.waitTime = 60, 300

bt0.type = SimpleBroadcastInterface
bt0.transmitSpeed = 2.25M
bt0.transmitRange = 11

Scenario.nrofHostGroups = 1
Group1.groupID = t

Group.msgTtl = 7200

Events.nrof = 1
Events1.class = MessageEventGenerator
Events1.interval = 60, 120
Events1.size = 50k, 150k
Events1.hosts = 0, 18
Events1.tohosts = 18, 36
Events1.prefix = M

Report.nrofReports = 2
Report.reportDir = reports/
Report.report1 = MessageStatsReport
Report.report2 = ContactTimesReport
